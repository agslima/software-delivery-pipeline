{
  "name": "secure-prescription-api",
  "version": "1.0.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Production-ready Node.js API",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "db:migrate": "knex migrate:latest --knexfile src/config/knexfile.js",
    "db:seed": "knex seed:run --knexfile src/config/knexfile.js",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit",
    "test:int": "jest tests/integration --runInBand",
    "test:watch": "jest tests/unit --watch",
    "test:coverage": "jest --coverage --coverageReporters=lcov",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/tests/jest.setup.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.1.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.2.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.16.3",
    "pino": "^8.17.0",
    "pino-http": "^9.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^8.3.2",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  }
}
