{
  "id": 13901177,
  "name": "branch_protection",
  "target": "branch",
  "source_type": "Repository",
  "source": "agslima/app-stayhealthy-pipeline",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "refs/heads/main"
      ]
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "required_reviewers": [],
        "require_code_owner_review": true,
        "require_last_push_approval": false,
        "required_review_thread_resolution": true,
        "allowed_merge_methods": [
          "squash"
        ]
      }
    },
    {
      "type": "code_scanning",
      "parameters": {
        "code_scanning_tools": [
          {
            "tool": "CodeQL",
            "security_alerts_threshold": "medium_or_higher",
            "alerts_threshold": "errors_and_warnings"
          }
        ]
      }
    },
    {
      "type": "code_quality",
      "parameters": {
        "severity": "warnings"
      }
    },
    {
      "type": "copilot_code_review",
      "parameters": {
        "review_on_push": true,
        "review_draft_pull_requests": true
      }
    },
    {
      "type": "required_linear_history"
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          {
            "context": "CodeQL",
            "integration_id": 57789
          },
          {
            "context": "Code Quality (client)",
            "integration_id": 15368
          },
          {
            "context": "Code Quality (server)",
            "integration_id": 15368
          },
          {
            "context": "Dockerfile Hygiene",
            "integration_id": 15368
          },
          {
            "context": "Governance Checks",
            "integration_id": 15368
          },
          {
            "context": "Migration Safety",
            "integration_id": 15368
          },
          {
            "context": "Security Scans",
            "integration_id": 15368
          },
          {
            "context": "Analyze (actions)",
            "integration_id": 15368
          },
          {
            "context": "Analyze (javascript-typescript)",
            "integration_id": 15368
          },
          {
            "context": "Analyze (python)",
            "integration_id": 15368
          }
        ]
      }
    },
    {
      "type": "required_signatures"
    },
    {
      "type": "creation"
    }
  ],
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ]
}